# DeepSeek API Key（必须替换为新生成的 key，之前泄露的已吊销）
DEEPSEEK_API_KEY=sk-YOUR_NEW_KEY_HERE

# Ollama（本地默认配置，通常不需要改）
OLLAMA_BASE_URL=http://localhost:11434

# Milvus（Docker 默认配置）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# PostgreSQL（Docker 默认配置）
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/atome_card_bot
SPRING_DATASOURCE_USERNAME=atome
SPRING_DATASOURCE_PASSWORD=atome123